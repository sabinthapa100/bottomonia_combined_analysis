     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"i", "\[Equal]", "j"}], " ", "&&", " ", 
        RowBox[{"i", "\[GreaterEqual]", "7"}], " ", "&&", " ", 
