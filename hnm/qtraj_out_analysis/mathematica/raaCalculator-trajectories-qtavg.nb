Cell[BoxData[
 RowBox[{
  RowBox[{"ColorHelix", "[", "z_", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "start", ",", "rot", ",", "gamma", ",", "amp", ",", "angle", ",", "red", 
      ",", "green", ",", "blue", ",", "min", ",", "max"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"start", "=", "0.6"}], ";", "\[IndentingNewLine]", 
     RowBox[{"rot", "=", "1.5"}], ";", "  ", "\[IndentingNewLine]", 
     RowBox[{"angle", "=", 
      RowBox[{"2.0", "*", "Pi", "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"start", "/", "3.0"}], "+", 
         RowBox[{"rot", "*", "z"}]}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"amp", " ", "=", " ", "0.15"}], ";", "\[IndentingNewLine]", 
     RowBox[{"red", "=", 
      RowBox[{"z", "+", 
       RowBox[{"amp", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "0.14861"}], " ", 
           RowBox[{"Cos", "[", "angle", "]"}]}], "+", 
          RowBox[{"1.78277", 
           RowBox[{"Sin", "[", "angle", "]"}]}]}], ")"}]}]}]}], ";", 
     RowBox[{"green", "=", 
      RowBox[{"z", "+", 
       RowBox[{"amp", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "0.29227"}], " ", 
           RowBox[{"Cos", "[", "angle", "]"}]}], "-", 
          RowBox[{"0.90649", 
           RowBox[{"Sin", "[", "angle", "]"}]}]}], ")"}]}]}]}], ";", 
     RowBox[{"blue", "=", 
      RowBox[{"z", "+", 
       RowBox[{"amp", 
        RowBox[{"(", 
         RowBox[{"1.97294", "*", 
          RowBox[{"Cos", "[", "angle", "]"}]}], ")"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"RGBColor", "[", 
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "-", "red"}], "]"}], "]"}], ",", 
       RowBox[{"Abs", "[", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "-", "green"}], "]"}], "]"}], ",", 
       RowBox[{"Abs", "[", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "-", "blue"}], "]"}], "]"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{3.74200482778002*^9},
