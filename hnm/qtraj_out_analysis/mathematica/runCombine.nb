Cell[BoxData[
 RowBox[{
  RowBox[{"loadRuns", "[", 
   RowBox[{"varName_", ",", "fileName_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"myRuns", ",", "res"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"myRuns", "=", 
      RowBox[{"FileNames", "[", 
       RowBox[{
       "wd", "<>", "\"\</output-\>\"", "<>", "energy", "<>", 
        "\"\</run-*\>\""}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"res", " ", "=", " ", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "<=", 
        RowBox[{"Length", "[", "myRuns", "]"}]}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"\"\<Loading \>\"", "<>", 
          RowBox[{"myRuns", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "<>", "\"\</\>\"", "<>", 
          "fileName"}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Get", "[", 
         RowBox[{
          RowBox[{"myRuns", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "<>", "\"\</\>\"", "<>", 
          "fileName"}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"res", ",", "varName"}], "]"}]}]}], "\[IndentingNewLine]", 
      "]"}], ";", "\[IndentingNewLine]", "res"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.914237943299334*^9, 3.914238035489229*^9}, {
  3.9142380987436*^9, 3.914238265001773*^9}, {3.914238307751995*^9, 
