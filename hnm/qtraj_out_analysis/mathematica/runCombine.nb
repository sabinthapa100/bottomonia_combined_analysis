 CellLabel->"In[2]:=",ExpressionUUID->"1226fd20-09f9-4a94-a746-f5abc2593093"],

Cell[BoxData[
 RowBox[{
  RowBox[{"processData", "[", 
   RowBox[{"data_", ",", "i_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"myData", ",", "myCenter", ",", "myMin", ",", "myMax"}], "}"}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"myCenter", "=", 
      RowBox[{"getValue", "/@", 
       RowBox[{
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"centralSet", ",", "i"}], "]"}], "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "2"}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"myData", " ", "=", " ", 
      RowBox[{
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"data", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "i"}], "]"}], "]"}], " ", "//", "Transpose"}],
          ",", "1"}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"myMin", "=", 
      RowBox[{"Min", "/@", 
       RowBox[{"Partition", "[", 
        RowBox[{
         RowBox[{"Min", "/@", 
          RowBox[{"getInterval", "/@", "myData"}]}], ",", 
         RowBox[{"Length", "[", "data", "]"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"myMax", "=", 
      RowBox[{"Max", "/@", 
       RowBox[{"Partition", "[", 
        RowBox[{
         RowBox[{"Max", "/@", 
          RowBox[{"getInterval", "/@", "myData"}]}], ",", 
         RowBox[{"Length", "[", "data", "]"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"binValues", ",", 
        RowBox[{"toAround", "/@", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"myCenter", ",", "myMin", ",", "myMax"}], "}"}], "  ", "//",
            "Transpose"}], ")"}]}]}], "}"}], "]"}]}]}], "\[IndentingNewLine]",
    "]"}]}]], "Input",
 CellChangeTimes->{{3.914239800205698*^9, 3.9142399383904*^9}, 
