Cell[BoxData[
 RowBox[{
  RowBox[{"ImportData", "[", "dir_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"mean", ",", "stderr"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Clear", "[", "data", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"data", "=", 
      RowBox[{"Import", "[", 
       RowBox[{
       "wd", "<>", "\"\</../\>\"", "<>", "dir", "<>", "\"\</ratios.tsv\>\""}],
        "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<Processing \>\"", ",", 
       RowBox[{"Length", "[", "data", "]"}], ",", "\"\< trajectories\>\""}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"mean", "=", 
      RowBox[{"Mean", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"stderr", "=", 
      RowBox[{
       RowBox[{"StandardDeviation", "[", "data", "]"}], "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"Length", "[", "data", "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"mapPoint", "/@", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"mean", ",", "stderr"}], "}"}], "]"}]}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
