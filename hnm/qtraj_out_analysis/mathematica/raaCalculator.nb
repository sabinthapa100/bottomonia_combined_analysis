Cell[BoxData[
 RowBox[{
  RowBox[{"computeRAA", "[", 
   RowBox[{"ratioData_", ",", "state_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "data", "}"}], ",", "\[IndentingNewLine]", 
