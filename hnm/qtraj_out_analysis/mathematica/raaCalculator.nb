     RowBox[{
      RowBox[{
       RowBox[{"data", " ", "=", 
        RowBox[{"ratioData", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "All", ",", "state"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"bVals", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", 
         RowBox[{"Around", "[", 
          RowBox[{
           RowBox[{"Mean", "[", "data", "]"}], ",", 
           RowBox[{"Max", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"StandardDeviation", "[", "data", "]"}], "/", 
              RowBox[{"Sqrt", "[", 
               RowBox[{"Length", "[", "data", "]"}], "]"}]}], ",", 
             RowBox[{"10", "^", 
              RowBox[{"(", 
               RowBox[{"-", "10"}], ")"}]}]}], "]"}]}], "]"}]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", 
        RowBox[{"Length", "[", "impactParams", "]"}]}], "}"}]}], "]"}]}], 
