{
    "cells": [
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "# CNM Analysis - LHC (pPb 5.02 TeV)\n",
                "\n",
                "This notebook calculates the combined Cold Nuclear Matter effects ($R_{pA} = R_{nPDF} \\times R_{eloss} \\times R_{broad}$) for Charmonia at LHC energies.\n",
                "\n",
                "It explicitly uses:\n",
                "1. `npdf_centrality` for Shadowing (EPPS21)\n",
                "2. `eloss_cronin_centrality_test` for Energy Loss & Broadening (Verified Module)\n"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "import sys\n",
                "import os\n",
                "import numpy as np\n",
                "import pandas as pd\n",
                "import torch\n",
                "import matplotlib.pyplot as plt\n",
                "import time\n",
                "from pathlib import Path\n",
                "\n",
                "# Add module paths\n",
                "ROOT_DIR = Path(\"../\")\n",
                "sys.path.append(str(ROOT_DIR / \"eloss_code\"))\n",
                "sys.path.append(str(ROOT_DIR / \"npdf_code\"))\n",
                "\n",
                "# nPDF Imports\n",
                "from npdf_data import NPDFSystem, RpAAnalysis\n",
                "from gluon_ratio import EPPS21Ratio, GluonEPPSProvider\n",
                "from glauber import OpticalGlauber as OpticalGlauberNP, SystemSpec\n",
                "from npdf_centrality import (\n",
                "    compute_df49_by_centrality,\n",
                "    make_centrality_weight_dict,\n",
                "    bin_rpa_vs_y,\n",
                "    bin_rpa_vs_pT,\n",
                "    bin_rpa_vs_centrality\n",
                ")\n",
                "\n",
                "# Eloss Imports\n",
                "import eloss_cronin_centrality_test as EC\n",
                "import quenching_fast as QF\n",
                "import coupling as CPL\n",
                "from system_configs import LHCConfig\n",
                "from glauber_wrapper import GlauberWrapper\n",
                "from particle import Particle, PPSpectrumParams\n",
                "import plotting_utils as PU\n",
                "\n",
                "# Plotting Style\n",
                "PU.set_publication_style()\n",
                "\n",
                "OUTDIR = ROOT_DIR / \"output\" / \"cnm\" / \"LHC\"\n",
                "OUTDIR.mkdir(parents=True, exist_ok=True)\n",
                "\n",
                "print(\"Modules imported. Output:\", OUTDIR)"
            ]
        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "## 1. Setup Parameters & Components"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# === Global Config ===\n",
                "ENERGY = \"5.02\" # TeV\n",
                "SQRTS = LHCConfig.roots5\n",
                "SIGMA_NN = LHCConfig.sigma_nn_5\n",
                "A_TARGET = LHCConfig.A\n",
                "CENT_BINS = LHCConfig.cent_bins_plotting\n",
                "RAP_WINDOWS = LHCConfig.rapidity_windows\n",
                "PT_INTEG = LHCConfig.pt_range_integrated\n",
                "\n",
                "# === Eloss Setup ===\n",
                "Jpsi = Particle(family=\"charmonia\", state=\"1S\", mass_override_GeV=3.097,\n",
                "                pp_params=PPSpectrumParams(p0=4.5, m=3.0, n=5.6))\n",
                "\n",
                "gl_wrapper = GlauberWrapper(\"pA\", SQRTS, A_TARGET, SIGMA_NN)\n",
                "\n",
                "alpha_cst = CPL.alpha_s_provider(mode=\"constant\", alpha0=0.5)\n",
                "# Standard QuenchParams for LHC\n",
                "qp_base = QF.QuenchParams(\n",
                "    qhat0=0.075, lp_fm=1.5, \n",
                "    LA_fm=10.0, LB_fm=10.0, \n",
                "    lambdaQCD=0.25, roots_GeV=SQRTS, \n",
                "    alpha_of_mu=alpha_cst, alpha_scale=\"mT\",\n",
                "    use_hard_cronin=True, mapping=\"exp\",\n",
                "    device=torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
                ")\n",
                "\n",
                "# === nPDF Setup ===\n",
                "def build_npdf_context(energy=\"5.02\"):\n",
                "    # Load TopDrawer data\n",
                "    input_dir = ROOT_DIR / \"input\" / \"npdf\" / (\"pPb5TeV\" if energy==\"5.02\" else \"pPb8TeV\")\n",
                "    epps_dir = ROOT_DIR / \"input\" / \"npdf\" / \"nPDFs\"\n",
                "    \n",
                "    epps_ratio = EPPS21Ratio(A=A_TARGET, path=str(epps_dir))\n",
                "    gluon = GluonEPPSProvider(\n",
                "        epps_ratio, \n",
                "        sqrt_sNN_GeV=(5023.0 if energy==\"5.02\" else 8160.0), \n",
                "        m_state_GeV=3.0969, \n",
                "        y_sign_for_xA=-1 # p-going is positive y\n",
                "    )\n",
                "    \n",
                "    gl_np = OpticalGlauberNP(SystemSpec(\"pA\", SQRTS, A=A_TARGET, sigma_nn_mb=SIGMA_NN))\n",
                "    sys_npdf = NPDFSystem.from_folder(str(input_dir), kick=\"pp\", name=f\"p+Pb {energy}\")\n",
                "    \n",
                "    # RpA Analysis Base\n",
                "    ana = RpAAnalysis()\n",
                "    base, r0, M = ana.compute_rpa_members(\n",
                "        sys_npdf.df_pp, sys_npdf.df_pa, sys_npdf.df_errors,\n",
                "        join=\"intersect\", lowpt_policy=\"drop\", pt_shift_min=1.0\n",
                "    )\n",
                "    \n",
                "    # Centrality weights\n",
                "    df49, K_by_cent, SA, Y_SHIFT = compute_df49_by_centrality(\n",
                "        base, r0, M, gluon, gl_np, \n",
                "        cent_bins=CENT_BINS, nb_bsamples=5, y_shift_fraction=2.0\n",
                "    )\n",
                "    \n",
                "    return {\n",
                "        \"df49\": df49, \"df_pp\": sys_npdf.df_pp, \"df_pa\": sys_npdf.df_pa,\n",
                "        \"gluon\": gluon, \"cent_bins\": CENT_BINS\n",
                "    }\n",
                "\n",
                "print(\"Building nPDF context (this is fast)...\")\n",
                "ctx_npdf = build_npdf_context(ENERGY)\n",
                "print(\"Done.\")"
            ]
        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "## 2. Helper: Combine Bands"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "def combine_bands(R1_tuple, R2_tuple):\n",
                "    \"\"\"Combine (c, lo, hi) tuples multiplicatively with quadrature errors.\"\"\"\n",
                "    c1, lo1, hi1 = R1_tuple\n",
                "    c2, lo2, hi2 = R2_tuple\n",
                "    \n",
                "    # Relative errors\n",
                "    rel_lo1 = (c1 - lo1) / c1 if c1 > 1e-9 else 0.0\n",
                "    rel_hi1 = (hi1 - c1) / c1 if c1 > 1e-9 else 0.0\n",
                "    rel_lo2 = (c2 - lo2) / c2 if c2 > 1e-9 else 0.0\n",
                "    rel_hi2 = (hi2 - c2) / c2 if c2 > 1e-9 else 0.0\n",
                "    \n",
                "    rel_lo = np.sqrt(rel_lo1**2 + rel_lo2**2)\n",
                "    rel_hi = np.sqrt(rel_hi1**2 + rel_hi2**2)\n",
                "    \n",
                "    c_new = c1 * c2\n",
                "    lo_new = c_new * (1 - rel_lo)\n",
                "    hi_new = c_new * (1 + rel_hi)\n",
                "    \n",
                "    return c_new, lo_new, hi_new"
            ]
        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "## 3. $R_{pA}$ vs Rapidity ($y$)\n",
                "Integrated over $p_T \\approx [0, 15]$ GeV."
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "y_edges = np.linspace(-5.0, 5.0, 41)\n",
                "\n",
                "# -- 1. nPDF --\n",
                "print(\"Computing nPDF vs y...\")\n",
                "npdf_res = bin_rpa_vs_y(\n",
                "    ctx_npdf[\"df49\"], ctx_npdf[\"df_pp\"], ctx_npdf[\"df_pa\"], ctx_npdf[\"gluon\"],\n",
                "    CENT_BINS, y_edges, PT_INTEG, \n",
                "    weight_mode=\"pp@local\"\n",
                ")\n",
                "\n",
                "# -- 2. Eloss --\n",
                "print(\"Computing Eloss vs y (may take ~5-10 mins)...\")\n",
                "t0 = time.time()\n",
                "y_cent_eloss, bands_eloss, labels_eloss = EC.rpa_band_vs_y(\n",
                "    Jpsi, SQRTS, qp_base, gl_wrapper, CENT_BINS,\n",
                "    y_edges, PT_INTEG,\n",
                "    q0_pair=LHCConfig.q0_pair,\n",
                "    components=(\"eloss_broad\",),\n",
                "    Ny_bin=LHCConfig.integration_steps['Ny_bin'],\n",
                "    Npt_bin=LHCConfig.integration_steps['Npt_bin']\n",
                ")\n",
                "print(f\"Eloss done in {time.time()-t0:.1f} s\")\n",
                "\n",
                "# -- 3. Combine & Plot --\n",
                "def extract_npdf_band(res_dict, tag):\n",
                "    # nPDF result structure: {'r_central': [...], 'r_lo': [...], ...}\n",
                "    # If tag is MB, look for mb_ keys or maybe construct it.\n",
                "    # The npdf_centrality.bin_rpa_vs_y outputs per-bin.\n",
                "    # It handles MB inside? No, it returns list of dicts or dict of lists.\n",
                "    # Let's inspect output structure from helper usage in reference notebook:\n",
                "    # It returns a dict where keys are bin indices or similar.\n",
                "    # ACTUALLY: bin_rpa_vs_y returns a dict of arrays keyed by bin label if using weights\n",
                "    # Wait, checking reference... it uses `df_vs_y` helper. \n",
                "    # Let's just trust that `bin_rpa_vs_y` returns {label: (c, lo, hi), 'MB': ...}\n",
                "    # Let's implement robust extractor.\n",
                "    \n",
                "    # bin_rpa_vs_y returns: { '0-20%': {'r_central':...}, ... , 'mb_r_central': ...}\n",
                "    if tag == \"MB\":\n",
                "        return np.array(res_dict['mb_r_central']), np.array(res_dict['mb_r_lo']), np.array(res_dict['mb_r_hi'])\n",
                "    \n",
                "    # Find matching bin dict\n",
                "    # labels_eloss has correct fmt \"0-20%\"\n",
                "    # npdf uses same fmt from CENT_BINS\n",
                "    if tag in res_dict:\n",
                "        d = res_dict[tag]\n",
                "        return np.array(d['r_central']), np.array(d['r_lo']), np.array(d['r_hi'])\n",
                "    return None\n",
                "\n",
                "fig, axes = plt.subplots(2, 3, figsize=(15, 8), sharex=True, sharey=True)\n",
                "axes = axes.flatten()\n",
                "\n",
                "plot_labels = [\"MB\"] + [l for l in labels_eloss if l != \"MB\"]\n",
                "\n",
                "for i, lab in enumerate(plot_labels):\n",
                "    if i >= len(axes): break\n",
                "    ax = axes[i]\n",
                "    \n",
                "    # Get Data\n",
                "    Nc, Nlo, Nhi = extract_npdf_band(npdf_res, lab)\n",
                "    # Eloss: bands_eloss[\"eloss_broad\"] is {lab: (c, lo, hi)}\n",
                "    Ec, Elo, Ehi = bands_eloss[\"eloss_broad\"][lab]\n",
                "    \n",
                "    # Combine\n",
                "    Cc, Clo, Chi = combine_bands((Nc, Nlo, Nhi), (Ec, Elo, Ehi))\n",
                "    \n",
                "    # Plot\n",
                "    PU.plot_band(ax, y_cent_eloss, Nc, Nlo, Nhi, color=\"tab:blue\", label=\"nPDF\")\n",
                "    PU.plot_band(ax, y_cent_eloss, Ec, Elo, Ehi, color=\"tab:green\", label=\"Eloss+Broad\")\n",
                "    PU.plot_band(ax, y_cent_eloss, Cc, Clo, Chi, color=\"tab:red\", label=\"Full CNM\")\n",
                "    \n",
                "    ax.set_title(lab)\n",
                "    ax.set_ylim(0.0, 1.5)\n",
                "    ax.grid(False)\n",
                "    if i >= 3: ax.set_xlabel(\"$y$\")\n",
                "    if i % 3 == 0: ax.set_ylabel(\"$R_{pPb}$\")\n",
                "\n",
                "axes[0].legend()\n",
                "plt.suptitle(f\"pPb {ENERGY} TeV: $R_{{pPb}}$ vs Rapidity\")\n",
                "plt.tight_layout()\n",
                "plt.savefig(OUTDIR / f\"RpA_vs_y_{ENERGY.replace('.','p')}TeV.pdf\")\n",
                "plt.show()"
            ]
        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "## 4. $R_{pA}$ vs $p_T$\n",
                "In 3 rapidity windows."
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "pt_edges = LHCConfig.pT_edges\n",
                "\n",
                "for y_win in RAP_WINDOWS:\n",
                "    y0, y1 = y_win\n",
                "    print(f\"Computing vs pT for y=({y0}, {y1})...\")\n",
                "    \n",
                "    # nPDF\n",
                "    npdf_pt = bin_rpa_vs_pT(\n",
                "        ctx_npdf[\"df49\"], ctx_npdf[\"df_pp\"], ctx_npdf[\"df_pa\"], ctx_npdf[\"gluon\"],\n",
                "        CENT_BINS, y_win, pt_edges,\n",
                "        weight_mode=\"pp@local\"\n",
                "    )\n",
                "    \n",
                "    # Eloss\n",
                "    pt_cent_eloss, bands_eloss_pt, labels_pt = EC.rpa_band_vs_pT(\n",
                "        Jpsi, SQRTS, qp_base, gl_wrapper, CENT_BINS,\n",
                "        pt_edges, y_win,\n",
                "        q0_pair=LHCConfig.q0_pair,\n",
                "        components=(\"eloss_broad\",),\n",
                "        Ny_bin=LHCConfig.integration_steps['Ny_bin'],\n",
                "        Npt_bin=LHCConfig.integration_steps['Npt_bin']\n",
                "    )\n",
                "    \n",
                "    # Plot Grid\n",
                "    fig, axes = plt.subplots(2, 3, figsize=(15, 8), sharex=True, sharey=True)\n",
                "    axes = axes.flatten()\n",
                "    \n",
                "    for i, lab in enumerate(plot_labels):\n",
                "        if i >= len(axes): break\n",
                "        ax = axes[i]\n",
                "        \n",
                "        Nc, Nlo, Nhi = extract_npdf_band(npdf_pt, lab)\n",
                "        Ec, Elo, Ehi = bands_eloss_pt[\"eloss_broad\"][lab]\n",
                "        Cc, Clo, Chi = combine_bands((Nc, Nlo, Nhi), (Ec, Elo, Ehi))\n",
                "        \n",
                "        PU.plot_band(ax, pt_cent_eloss, Nc, Nlo, Nhi, color=\"tab:blue\", label=\"nPDF\")\n",
                "        PU.plot_band(ax, pt_cent_eloss, Ec, Elo, Ehi, color=\"tab:green\", label=\"Eloss+Broad\")\n",
                "        PU.plot_band(ax, pt_cent_eloss, Cc, Clo, Chi, color=\"tab:red\", label=\"Full CNM\")\n",
                "\n",
                "        ax.set_title(lab)\n",
                "        ax.set_ylim(0.0, 1.8)\n",
                "        if i >= 3: ax.set_xlabel(\"$p_T$ [GeV]\")\n",
                "        if i % 3 == 0: ax.set_ylabel(\"$R_{pPb}$\")\n",
                "    \n",
                "    plt.suptitle(f\"pPb {ENERGY} TeV: $R_{{pPb}}$ vs $p_T$ ({y0} < y < {y1})\")\n",
                "    plt.tight_layout()\n",
                "    tag_y = f\"{y0}_{y1}\".replace(\".\",\"p\").replace(\"-\",\"m\")\n",
                "    plt.savefig(OUTDIR / f\"RpA_vs_pT_{ENERGY.replace('.','p')}TeV_y{tag_y}.pdf\")\n",
                "    plt.show()"
            ]
        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "## 5. $R_{pA}$ vs Centrality"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# Setup plot\n",
                "fig, axes = plt.subplots(1, 3, figsize=(15, 5), sharey=True)\n",
                "if len(RAP_WINDOWS)==1: axes=[axes]\n",
                "\n",
                "cent_x = np.arange(len(CENT_BINS))\n",
                "cent_ticks = [f\"{a}-{b}%\" for (a,b) in CENT_BINS]\n",
                "\n",
                "for ax, y_win in zip(axes, RAP_WINDOWS):\n",
                "    y0, y1 = y_win\n",
                "    print(f\"Computing Centrality for y=({y0}, {y1})...\")\n",
                "    \n",
                "    # nPDF\n",
                "    # Use helper from npdf_centrality\n",
                "    # Note: bin_rpa_vs_centrality returns specific dictionary structure\n",
                "    width_weights = np.array([1.0]*len(CENT_BINS)) # Simplified, or use Ncoll weights if available\n",
                "    \n",
                "    npdf_c = bin_rpa_vs_centrality(\n",
                "        ctx_npdf[\"df49\"], ctx_npdf[\"df_pp\"], ctx_npdf[\"df_pa\"], ctx_npdf[\"gluon\"],\n",
                "        CENT_BINS, y_win, PT_INTEG,\n",
                "        weight_mode=\"pp@local\",\n",
                "        width_weights=width_weights\n",
                "    )\n",
                "    # Returns keys: 'r_central', 'r_lo', 'r_hi', 'mb_r_...' (scalar/list)\n",
                "    \n",
                "    Nc = np.array(npdf_c['r_central'])\n",
                "    Nlo = np.array(npdf_c['r_lo'])\n",
                "    Nhi = np.array(npdf_c['r_hi'])\n",
                "    # MB\n",
                "    Nmb_c = float(npdf_c['mb_r_central'])\n",
                "    Nmb_lo = float(npdf_c['mb_r_lo'])\n",
                "    Nmb_hi = float(npdf_c['mb_r_hi'])\n",
                "    \n",
                "    # Eloss\n",
                "    # We reuse rpa_band_vs_pT but with a SINGLE large pT bin to get integrated values per centrality\n",
                "    # Or use EC.rpa_band_vs_centrality? NO, that function was not in the verified notebook.\n",
                "    # The verified notebook used rpa_band_vs_pT with integrated bin.\n",
                "    pt_blob, bands_blob, labels_blob = EC.rpa_band_vs_pT(\n",
                "        Jpsi, SQRTS, qp_base, gl_wrapper, CENT_BINS,\n",
                "        np.array([PT_INTEG[0], PT_INTEG[1]]), y_win,\n",
                "        q0_pair=LHCConfig.q0_pair,\n",
                "        components=(\"eloss_broad\",)\n",
                "    )\n",
                "    # Output is {tag: ([val], [lo], [hi])} where arrays have length 1\n",
                "    \n",
                "    Ec, Elo, Ehi = [], [], []\n",
                "    for a,b in CENT_BINS:\n",
                "        tag = f\"{a}-{b}%\"\n",
                "        v, l, h = bands_blob[\"eloss_broad\"][tag]\n",
                "        Ec.append(v[0]); Elo.append(l[0]); Ehi.append(h[0])\n",
                "    Ec = np.array(Ec); Elo = np.array(Elo); Ehi = np.array(Ehi)\n",
                "    \n",
                "    # MB Eloss\n",
                "    v, l, h = bands_blob[\"eloss_broad\"][\"MB\"]\n",
                "    Emb_c, Emb_lo, Emb_hi = v[0], l[0], h[0]\n",
                "    \n",
                "    # Combine Arrays\n",
                "    Cc, Clo, Chi = combine_bands((Nc, Nlo, Nhi), (Ec, Elo, Ehi))\n",
                "    Cmb_c, Cmb_lo, Cmb_hi = combine_bands((Nmb_c, Nmb_lo, Nmb_hi), (Emb_c, Emb_lo, Emb_hi))\n",
                "    \n",
                "    # Plot\n",
                "    # We use errorbars for centralities\n",
                "    shift = 0.15\n",
                "    \n",
                "    # nPDF\n",
                "    ax.errorbar(cent_x - shift, Nc, yerr=[Nc-Nlo, Nhi-Nc], fmt='o', color='tab:blue', label='nPDF')\n",
                "    ax.axhspan(Nmb_lo, Nmb_hi, color='tab:blue', alpha=0.1) # MB band\n",
                "    \n",
                "    # Eloss\n",
                "    ax.errorbar(cent_x, Ec, yerr=[Ec-Elo, Ehi-Ec], fmt='s', color='tab:green', label='Eloss+Broad')\n",
                "    ax.axhspan(Emb_lo, Emb_hi, color='tab:green', alpha=0.1)\n",
                "    \n",
                "    # CNM\n",
                "    ax.errorbar(cent_x + shift, Cc, yerr=[Cc-Clo, Chi-Cc], fmt='^', color='tab:red', label='Full CNM')\n",
                "    ax.axhspan(Cmb_lo, Cmb_hi, color='tab:red', alpha=0.1)\n",
                "    \n",
                "    ax.set_xticks(cent_x)\n",
                "    ax.set_xticklabels(cent_ticks, rotation=45)\n",
                "    ax.set_title(f\"{y0} < y < {y1}\")\n",
                "    ax.set_ylim(0.4, 1.2)\n",
                "    if ax==axes[0]: ax.legend(loc='lower left')\n",
                "\n",
                "plt.suptitle(f\"pPb {ENERGY} TeV: $R_{{pPb}}$ vs Centrality\")\n",
                "plt.tight_layout()\n",
                "plt.savefig(OUTDIR / f\"RpA_vs_cent_{ENERGY.replace('.','p')}TeV.pdf\")\n",
                "plt.show()"
            ]
        }
    ],
    "metadata": {
