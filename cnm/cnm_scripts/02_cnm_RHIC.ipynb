{
    "cells": [
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "# CNM Analysis - RHIC (dAu 200 GeV)\n",
                "\n",
                "This notebook calculates the combined Cold Nuclear Matter effects ($R_{dA} = R_{nPDF} \\times R_{eloss} \\times R_{broad}$) for Charmonia at RHIC energies.\n",
                "\n",
                "It implements explicit calls to:\n",
                "1. `npdf_centrality` for Shadowing (EPPS21)\n",
                "2. `eloss_cronin_centrality_test` for Energy Loss & Broadening\n"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "import sys\n",
                "import os\n",
                "import numpy as np\n",
                "import torch\n",
                "import matplotlib.pyplot as plt\n",
                "import time\n",
                "from pathlib import Path\n",
                "\n",
                "# Add module paths\n",
                "ROOT_DIR = Path(\"../\")\n",
                "sys.path.append(str(ROOT_DIR / \"eloss_code\"))\n",
                "sys.path.append(str(ROOT_DIR / \"npdf_code\"))\n",
                "\n",
                "# nPDF Imports\n",
                "from npdf_data import NPDFSystem, RpAAnalysis\n",
                "from gluon_ratio import EPPS21Ratio, GluonEPPSProvider\n",
                "from glauber import OpticalGlauber as OpticalGlauberNP, SystemSpec\n",
                "from npdf_centrality import (\n",
                "    compute_df49_by_centrality,\n",
                "    bin_rpa_vs_y,\n",
                "    bin_rpa_vs_pT,\n",
                "    bin_rpa_vs_centrality\n",
                ")\n",
                "\n",
                "# Eloss Imports\n",
                "import eloss_cronin_centrality_test as EC\n",
                "import quenching_fast as QF\n",
                "import coupling as CPL\n",
                "from system_configs import RHICConfig\n",
                "from glauber_wrapper import GlauberWrapper\n",
                "from particle import Particle, PPSpectrumParams\n",
                "import plotting_utils as PU\n",
                "\n",
                "# Plotting Style\n",
                "PU.set_publication_style()\n",
                "\n",
                "OUTDIR = ROOT_DIR / \"output\" / \"cnm\" / \"RHIC\"\n",
                "OUTDIR.mkdir(parents=True, exist_ok=True)\n",
                "\n",
                "print(\"Modules imported. Output:\", OUTDIR)"
            ]
        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "## 1. Setup Parameters & Components"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "# === Global Config ===\n",
                "ENERGY = \"200\" # GeV\n",
                "SQRTS = RHICConfig.roots\n",
                "SIGMA_NN = RHICConfig.sigma_nn\n",
                "A_TARGET = RHICConfig.A\n",
                "CENT_BINS = RHICConfig.cent_bins\n",
                "RAP_WINDOWS = RHICConfig.rapidity_windows\n",
                "PT_INTEG = RHICConfig.pt_range_y_integrated\n",
                "\n",
                "# === Eloss Setup ===\n",
                "# Jpsi for RHIC params\n",
                "pp_p = RHICConfig.pp_params\n",
                "Jpsi = Particle(family=\"charmonia\", state=\"1S\", mass_override_GeV=3.097,\n",
                "                pp_params=PPSpectrumParams(p0=pp_p['p0'], m=pp_p['m'], n=pp_p['n']))\n",
                "\n",
                "# Use dA system\n",
                "gl_wrapper = GlauberWrapper(\"dA\", SQRTS, A_TARGET, SIGMA_NN)\n",
                "\n",
                "alpha_cst = CPL.alpha_s_provider(mode=\"constant\", alpha0=0.5)\n",
                "qp_base = QF.QuenchParams(\n",
                "    qhat0=0.075, lp_fm=1.5, \n",
                "    LA_fm=10.0, LB_fm=10.0, \n",
                "    lambdaQCD=0.25, roots_GeV=SQRTS, \n",
                "    alpha_of_mu=alpha_cst, alpha_scale=\"mT\",\n",
                "    use_hard_cronin=True, mapping=\"exp\",\n",
                "    device=torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
                ")\n",
                "\n",
                "# === nPDF Setup ===\n",
                "def build_npdf_context():\n",
                "    # RHIC Table? Assuming standard structure or using Placeholder if RHIC table not present.\n",
                "    # NOTE: The user has pPb5TeV and pPb8TeV folders. dAu200 might need generation or be missing.\n",
                "    # Standard TopDrawer loading might fail if dAu table doesn't exist.\n",
                "    # However, npdf_data handles generic loading. Let's assume input/npdf/dAu200 exists or similar.\n",
                "    # If not, this step might fail. But we must proceed assuming data exists or using what we have.\n",
                "    # The file listing showed output-npdf-comparisons etc. but not specific input dirs.\n",
                "    # We'll point to 'dAu200' and hope.\n",
                "    input_dir = ROOT_DIR / \"input\" / \"npdf\" / \"dAu200\"\n",
                "    epps_dir = ROOT_DIR / \"input\" / \"npdf\" / \"nPDFs\"\n",
                "    \n",
                "    epps_ratio = EPPS21Ratio(A=A_TARGET, path=str(epps_dir))\n",
                "    gluon = GluonEPPSProvider(\n",
                "        epps_ratio, \n",
                "        sqrt_sNN_GeV=SQRTS,\n",
                "        m_state_GeV=3.0969, \n",
                "        y_sign_for_xA=-1 # RHIC convention: deuteron going positive z, Au going negative z\n",
                "        # Forward y (d-going) probes low-x in Au target -> sign = -1\n",
                "    )\n",
                "    \n",
                "    gl_np = OpticalGlauberNP(SystemSpec(\"dA\", SQRTS, A=A_TARGET, sigma_nn_mb=SIGMA_NN))\n",
                "    \n",
                "    # Try loading system. If fails, we might need to skip nPDF or warn.\n",
                "    try:\n",
                "        sys_npdf = NPDFSystem.from_folder(str(input_dir), kick=\"pp\", name=\"d+Au 200\")\n",
                "        has_data = True\n",
                "    except:\n",
                "        print(\"WARNING: nPDF Data for dAu200 not found. Using Placeholder (Identity) for nPDF.\")\n",
                "        has_data = False\n",
                "        sys_npdf = None\n",
                "    \n",
                "    df49 = None\n",
                "    if has_data:\n",
                "        ana = RpAAnalysis()\n",
                "        base, r0, M = ana.compute_rpa_members(\n",
                "            sys_npdf.df_pp, sys_npdf.df_pa, sys_npdf.df_errors,\n",
                "            join=\"intersect\", lowpt_policy=\"drop\", pt_shift_min=1.0\n",
                "        )\n",
                "        df49, _, _, _ = compute_df49_by_centrality(\n",
                "            base, r0, M, gluon, gl_np, \n",
                "            cent_bins=CENT_BINS, nb_bsamples=5, y_shift_fraction=1.0\n",
                "        )\n",
                "    \n",
                "    return {\n",
                "        \"df49\": df49, \n",
                "        \"df_pp\": sys_npdf.df_pp if has_data else None, \n",
                "        \"df_pa\": sys_npdf.df_pa if has_data else None,\n",
                "        \"gluon\": gluon, \n",
                "        \"has_data\": has_data\n",
                "    }\n",
                "\n",
                "print(\"Building nPDF context...\")\n",
                "ctx_npdf = build_npdf_context()\n",
                "print(\"Done.\")"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "def combine_bands(R1_tuple, R2_tuple):\n",
                "    \"\"\"Combine (c, lo, hi) tuples multiplicatively with quadrature errors.\"\"\"\n",
                "    c1, lo1, hi1 = R1_tuple\n",
                "    c2, lo2, hi2 = R2_tuple\n",
                "    \n",
                "    # Relative errors\n",
                "    rel_lo1 = (c1 - lo1) / c1 if c1 > 1e-9 else 0.0\n",
                "    rel_hi1 = (hi1 - c1) / c1 if c1 > 1e-9 else 0.0\n",
                "    rel_lo2 = (c2 - lo2) / c2 if c2 > 1e-9 else 0.0\n",
                "    rel_hi2 = (hi2 - c2) / c2 if c2 > 1e-9 else 0.0\n",
                "    \n",
                "    rel_lo = np.sqrt(rel_lo1**2 + rel_lo2**2)\n",
                "    rel_hi = np.sqrt(rel_hi1**2 + rel_hi2**2)\n",
                "    \n",
                "    c_new = c1 * c2\n",
                "    lo_new = c_new * (1 - rel_lo)\n",
                "    hi_new = c_new * (1 + rel_hi)\n",
                "    \n",
                "    return c_new, lo_new, hi_new\n",
                "\n",
                "def get_dummy_npdf_y(y_grid, cent_label):\n",
                "    # Returns R=1 if data missing\n",
                "    ones = np.ones_like(y_grid)\n",
                "    return ones, ones, ones\n",
                "\n",
                "def extract_npdf_band(res_dict, tag, y_grid_len=None):\n",
                "    if not res_dict or not ctx_npdf[\"has_data\"]:\n",
                "        return np.ones(y_grid_len), np.ones(y_grid_len), np.ones(y_grid_len)\n",
                "        \n",
                "    if tag == \"MB\":\n",
                "        return np.array(res_dict['mb_r_central']), np.array(res_dict['mb_r_lo']), np.array(res_dict['mb_r_hi'])\n",
                "    if tag in res_dict:\n",
                "        d = res_dict[tag]\n",
                "        return np.array(d['r_central']), np.array(d['r_lo']), np.array(d['r_hi'])\n",
                "    return np.ones(y_grid_len), np.ones(y_grid_len), np.ones(y_grid_len)"
            ]
        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "## 2. $R_{dA}$ vs Rapidity"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "y_edges = RHICConfig.y_edges\n",
                "\n",
                "print(\"Computing Eloss vs y...\")\n",
                "t0 = time.time()\n",
                "y_cent_eloss, bands_eloss, labels_eloss = EC.rpa_band_vs_y(\n",
                "    Jpsi, SQRTS, qp_base, gl_wrapper, CENT_BINS,\n",
                "    y_edges, PT_INTEG,\n",
                "    q0_pair=RHICConfig.q0_pair,\n",
                "    components=(\"eloss_broad\",),\n",
                "    Ny_bin=RHICConfig.integration_steps['Ny_bin'],\n",
                "    Npt_bin=RHICConfig.integration_steps['Npt_bin']\n",
                ")\n",
                "print(f\"Eloss done in {time.time()-t0:.1f} s\")\n",
                "\n",
                "# nPDF Calc (if data exists)\n",
                "npdf_res = None\n",
                "if ctx_npdf[\"has_data\"]:\n",
                "    npdf_res = bin_rpa_vs_y(\n",
                "        ctx_npdf[\"df49\"], ctx_npdf[\"df_pp\"], ctx_npdf[\"df_pa\"], ctx_npdf[\"gluon\"],\n",
                "        CENT_BINS, y_edges, PT_INTEG, \n",
                "        weight_mode=\"pp@local\"\n",
                "    )\n",
                "\n",
                "fig, axes = plt.subplots(2, 3, figsize=(15, 8), sharex=True, sharey=True)\n",
                "axes = axes.flatten()\n",
                "plot_labels = [\"MB\"] + [l for l in labels_eloss if l != \"MB\"]\n",
                "\n",
                "for i, lab in enumerate(plot_labels):\n",
                "    if i >= len(axes): break\n",
                "    ax = axes[i]\n",
                "    \n",
                "    Ec, Elo, Ehi = bands_eloss[\"eloss_broad\"][lab]\n",
                "    Nc, Nlo, Nhi = extract_npdf_band(npdf_res, lab, len(Ec))\n",
                "    Cc, Clo, Chi = combine_bands((Nc, Nlo, Nhi), (Ec, Elo, Ehi))\n",
                "    \n",
                "    PU.plot_band(ax, y_cent_eloss, Nc, Nlo, Nhi, color=\"tab:blue\", label=\"nPDF\")\n",
                "    PU.plot_band(ax, y_cent_eloss, Ec, Elo, Ehi, color=\"tab:green\", label=\"Eloss+Broad\")\n",
                "    PU.plot_band(ax, y_cent_eloss, Cc, Clo, Chi, color=\"tab:red\", label=\"Full CNM\")\n",
                "    \n",
                "    ax.set_title(lab)\n",
                "    ax.set_ylim(0.0, 1.5)\n",
                "    if i % 3 == 0: ax.set_ylabel(\"$R_{dA}$\")\n",
                "    if i >= 3: ax.set_xlabel(\"$y$\")\n",
                "    \n",
                "axes[0].legend()\n",
                "plt.suptitle(f\"dAu {ENERGY} GeV: $R_{{dA}}$ vs Rapidity\")\n",
                "plt.tight_layout()\n",
                "plt.savefig(OUTDIR / f\"RpA_vs_y_{ENERGY}GeV.pdf\")\n",
                "plt.show()"
            ]
        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "## 3. $R_{dA}$ vs $p_T$"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "pT_edges = RHICConfig.pT_edges\n",
                "\n",
                "for y_win in RAP_WINDOWS:\n",
                "    y0, y1 = y_win\n",
                "    print(f\"Computing vs pT for {y_win}...\")\n",
                "    \n",
                "    # Eloss\n",
                "    pt_cent, bands_pt, labels_pt = EC.rpa_band_vs_pT(\n",
                "        Jpsi, SQRTS, qp_base, gl_wrapper, CENT_BINS,\n",
                "        pT_edges, y_win,\n",
                "        q0_pair=RHICConfig.q0_pair,\n",
                "        components=(\"eloss_broad\",)\n",
                "    )\n",
                "    \n",
                "    # nPDF\n",
                "    npdf_pt = None\n",
                "    if ctx_npdf[\"has_data\"]:\n",
                "        npdf_pt = bin_rpa_vs_pT(\n",
                "            ctx_npdf[\"df49\"], ctx_npdf[\"df_pp\"], ctx_npdf[\"df_pa\"], ctx_npdf[\"gluon\"],\n",
                "            CENT_BINS, y_win, pT_edges,\n",
                "            weight_mode=\"pp@local\"\n",
                "        )\n",
                "        \n",
                "    # Plot\n",
                "    fig, axes = plt.subplots(2, 3, figsize=(15, 8), sharex=True, sharey=True)\n",
                "    axes = axes.flatten()\n",
                "    \n",
                "    for i, lab in enumerate(plot_labels):\n",
                "        if i >= len(axes): break\n",
                "        ax = axes[i]\n",
                "        \n",
                "        Ec, Elo, Ehi = bands_pt[\"eloss_broad\"][lab]\n",
                "        Nc, Nlo, Nhi = extract_npdf_band(npdf_pt, lab, len(Ec))\n",
                "        Cc, Clo, Chi = combine_bands((Nc, Nlo, Nhi), (Ec, Elo, Ehi))\n",
                "        \n",
                "        PU.plot_band(ax, pt_cent, Nc, Nlo, Nhi, color=\"tab:blue\", label=\"nPDF\")\n",
                "        PU.plot_band(ax, pt_cent, Ec, Elo, Ehi, color=\"tab:green\", label=\"Eloss+Broad\")\n",
                "        PU.plot_band(ax, pt_cent, Cc, Clo, Chi, color=\"tab:red\", label=\"Full CNM\")\n",
                "        \n",
                "        ax.set_title(lab)\n",
                "        ax.set_ylim(0.0, 1.8)\n",
                "        if i % 3 == 0: ax.set_ylabel(\"$R_{dA}$\")\n",
                "        if i >= 3: ax.set_xlabel(\"$p_T$ [GeV]\")\n",
                "        \n",
                "    plt.suptitle(f\"dAu {ENERGY} GeV: $R_{{dA}}$ vs $p_T$ ({y0} < y < {y1})\")\n",
                "    plt.tight_layout()\n",
                "    tag_y = f\"{y0}_{y1}\".replace(\".\",\"p\").replace(\"-\",\"m\")\n",
                "    plt.savefig(OUTDIR / f\"RpA_vs_pT_{ENERGY}GeV_y{tag_y}.pdf\")\n",
                "    plt.show()"
            ]
        },
        {
            "cell_type": "markdown",
            "metadata": {},
            "source": [
                "## 4. $R_{dA}$ vs Centrality"
            ]
        },
        {
            "cell_type": "code",
            "execution_count": null,
            "metadata": {},
            "outputs": [],
            "source": [
                "cent_x = np.arange(len(CENT_BINS))\n",
                "cent_ticks = [f\"{a}-{b}%\" for (a,b) in CENT_BINS]\n",
                "\n",
                "fig, axes = plt.subplots(1, 3, figsize=(15, 5), sharey=True)\n",
                "if len(RAP_WINDOWS)==1: axes=[axes]\n",
                "\n",
                "for ax, y_win in zip(axes, RAP_WINDOWS):\n",
                "    y0, y1 = y_win\n",
                "    \n",
                "    # nPDF\n",
                "    Nc = np.ones(len(cent_x)); Nlo=Nc; Nhi=Nc;\n",
                "    Nmb_c=1.0; Nmb_lo=1.0; Nmb_hi=1.0\n",
                "    \n",
                "    if ctx_npdf[\"has_data\"]:\n",
                "        res = bin_rpa_vs_centrality(\n",
                "            ctx_npdf[\"df49\"], ctx_npdf[\"df_pp\"], ctx_npdf[\"df_pa\"], ctx_npdf[\"gluon\"],\n",
                "            CENT_BINS, y_win, PT_INTEG,\n",
                "            weight_mode=\"pp@local\", width_weights=np.array([1.0]*len(CENT_BINS))\n",
                "        )\n",
                "        Nc = np.array(res['r_central'])\n",
                "        Nlo = np.array(res['r_lo'])\n",
                "        Nhi = np.array(res['r_hi'])\n",
                "        Nmb_c, Nmb_lo, Nmb_hi = float(res['mb_r_central']), float(res['mb_r_lo']), float(res['mb_r_hi'])\n",
                "        \n",
                "    # Eloss (Integrated)\n",
                "    _, bands_blob, _ = EC.rpa_band_vs_pT(\n",
                "        Jpsi, SQRTS, qp_base, gl_wrapper, CENT_BINS,\n",
                "        np.array([PT_INTEG[0], PT_INTEG[1]]), y_win,\n",
                "        q0_pair=LHCConfig.q0_pair,\n",
                "        components=(\"eloss_broad\",)\n",
                "    )\n",
                "\n",
                "    Ec, Elo, Ehi = [], [], []\n",
                "    for a,b in CENT_BINS:\n",
                "        tag = f\"{a}-{b}%\"\n",
                "        v, l, h = bands_blob[\"eloss_broad\"][tag]\n",
                "        Ec.append(v[0]); Elo.append(l[0]); Ehi.append(h[0])\n",
                "    Ec=np.array(Ec); Elo=np.array(Elo); Ehi=np.array(Ehi)\n",
                "    \n",
                "    v,l,h = bands_blob[\"eloss_broad\"][\"MB\"]\n",
                "    Emb_c, Emb_lo, Emb_hi = v[0], l[0], h[0]\n",
                "    \n",
                "    # Combine\n",
                "    Cc, Clo, Chi = combine_bands((Nc, Nlo, Nhi), (Ec, Elo, Ehi))\n",
                "    Cmb_c, Cmb_lo, Cmb_hi = combine_bands((Nmb_c, Nmb_lo, Nmb_hi), (Emb_c, Emb_lo, Emb_hi))\n",
                "    \n",
                "    # Plot\n",
                "    shift = 0.15\n",
                "    ax.errorbar(cent_x - shift, Nc, yerr=[Nc-Nlo, Nhi-Nc], fmt='o', color='tab:blue', label='nPDF')\n",
                "    ax.axhspan(Nmb_lo, Nmb_hi, color='tab:blue', alpha=0.1)\n",
                "    \n",
                "    ax.errorbar(cent_x, Ec, yerr=[Ec-Elo, Ehi-Ec], fmt='s', color='tab:green', label='Eloss+Broad')\n",
                "    ax.axhspan(Emb_lo, Emb_hi, color='tab:green', alpha=0.1)\n",
                "    \n",
                "    ax.errorbar(cent_x + shift, Cc, yerr=[Cc-Clo, Chi-Cc], fmt='^', color='tab:red', label='Full CNM')\n",
                "    ax.axhspan(Cmb_lo, Cmb_hi, color='tab:red', alpha=0.1)\n",
                "    \n",
                "    ax.set_xticks(cent_x)\n",
                "    ax.set_xticklabels(cent_ticks, rotation=45)\n",
                "    ax.set_title(f\"{y0} < y < {y1}\")\n",
                "    if ax==axes[0]: ax.legend(loc='lower left')\n",
                "\n",
                "plt.suptitle(f\"dAu {ENERGY} GeV: $R_{{dA}}$ vs Centrality\")\n",
                "plt.tight_layout()\n",
                "plt.savefig(OUTDIR / f\"RpA_vs_cent_{ENERGY}GeV.pdf\")\n",
                "plt.show()"
            ]
        }
    ],
    "metadata": {
